{
  "version": 2,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOW-FROM https://outlook.office.com" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://outlook.office.com https://*.officeapps.live.com" }
      ]
    }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  }
}
