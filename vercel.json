{
  "version": 2,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(taskpane|commands)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  }
}
